APP_ENV=development
DATABASE_URL=sqlite:///./data/ai_radar.db
RSS_URLS=
GITHUB_TOKEN=
X_BEARER_TOKEN=
COMFYUI_URL=
COLLECTION_INTERVAL_MINUTES=60
SCHEDULER_ENABLED=true
DRAFT_GENERATOR_PROVIDER=template
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
# Startup validates model access. If your API project exposes it instead, set OPENAI_MODEL=gpt-5.5

# Source-quality weights. Set to 0 to exclude a source from heat scoring.
SOURCE_WEIGHT_ARXIV=1.40
SOURCE_WEIGHT_GITHUB=1.20
SOURCE_WEIGHT_HACKER_NEWS=0.85
SOURCE_WEIGHT_RSS=1.00
SOURCE_WEIGHT_X=1.10
SOURCE_WEIGHT_BILIBILI=1.00
SOURCE_WEIGHT_DEFAULT=1.00
# Adds a multiplier for a configured authoritative author. 0.65 means +65%.
AUTHORITY_AUTHOR_BONUS=0.65
HEAT_FRESHNESS_WEIGHT=1.00
HEAT_ENGAGEMENT_WEIGHT=1.00

# Comma-separated public-author allowlists. X collection also needs X_BEARER_TOKEN.
X_AUTHOR_USERNAMES=
BILIBILI_AUTHOR_MIDS=
# Optional trusted display names used for any source platform.
TRUSTED_AUTHOR_NAMES=
